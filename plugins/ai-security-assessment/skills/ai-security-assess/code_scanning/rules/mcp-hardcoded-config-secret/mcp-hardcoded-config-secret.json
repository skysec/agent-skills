{
  "servers": {
    "my-server": {
      "command": "python",
      "args": ["server.py"],
      "env": {
        // ruleid: mcp-hardcoded-config-secret-generic
        "OPENAI_API_KEY": "sk-1234567890abcdef1234567890abcdef"
      }
    },
    "another-server": {
      "command": "node",
      "args": ["index.js"],
      "env": {
        // ruleid: mcp-hardcoded-config-secret-generic
        "HF_TOKEN": "hf_abcdefghijklmnopqrstuvwxyz"
      }
    },
    "safe-server": {
      "command": "python",
      "args": ["server.py"],
      "env": {
        // ok: mcp-hardcoded-config-secret-generic
        "API_KEY": "${OPENAI_API_KEY}"
      }
    },
    "also-safe": {
      "command": "node",
      "args": ["index.js"],
      "env": {
        // ok: mcp-hardcoded-config-secret-generic
        "TOKEN": "not-a-real-key-format"
      }
    }
  }
